{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Server (Local)",
      "runtimeArgs": ["-r", "ts-node/register"],
      "args": ["${workspaceFolder}/apps/server/src/server.ts"],
      "cwd": "${workspaceFolder}",
      "protocol": "inspector",
      "internalConsoleOptions": "openOnSessionStart",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Docker Server",
      "port": 9229,
      "address": "localhost",
      "localRoot": "${workspaceFolder}/apps/server/src",
      "remoteRoot": "/usr/src/app/apps/server/src",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}

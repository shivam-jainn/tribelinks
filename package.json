{
  "name": "modular-tracker-monorepo",
  "version": "1.0.0",
  "description": "Modular Short-Link, Pixel Tracking Server and SDK monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "ts-node scripts/db-setup.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "tsx": "^4.23.1"
  }
}
